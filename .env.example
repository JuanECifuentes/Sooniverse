# ──────────────────────────────────────────────
# Sooniverse - Environment Variables (TEMPLATE)
# Copy this file to .env and fill in the real values.
# ──────────────────────────────────────────────

# Django core
SECRET_KEY=
DEBUG=True
LOCAL=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=workforce_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Cache (Redis)
REDIS_URL=redis://127.0.0.1:6379/1

# Email (AWS SES)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION_NAME=us-east-1
AWS_SES_RETURN_PATH=

# Django Q2
Q_CLUSTER_NAME=sooniverse-q
Q_CLUSTER_WORKERS=2
Q_CLUSTER_TIMEOUT=90
Q_CLUSTER_RECYCLER=300
